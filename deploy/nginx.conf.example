# Nginx reverse proxy para COUNTER_STRYKE en VPS
# Copiar a: /etc/nginx/sites-available/counter-stryke
# ln -s /etc/nginx/sites-available/counter-stryke /etc/nginx/sites-enabled/
# nginx -t && systemctl reload nginx

server {
    listen 80;
    server_name tu-dominio.com www.tu-dominio.com;

    # Certbot: sudo certbot --nginx -d tu-dominio.com

    client_max_body_size 1m;

    location / {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;

        # WebSockets (Socket.io)
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;
    }
}
